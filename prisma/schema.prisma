generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Epoch {
  id     Int     @id @default(autoincrement())
  slug   String  @unique
  label  String
  events Event[]
}

model Event {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  year        Int
  title       String
  description String
  content     String
  epochId     Int
  epoch       Epoch  @relation(fields: [epochId], references: [id])
}

model Source {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  title       String
  year        Int
  nature      String
  author      String
  origin      String
  description String
  imageUrl    String
  color       String
  nasdiN      String
  nasdiA      String
  nasdiS      String
  nasdiD      String
  nasdiI      String
}
